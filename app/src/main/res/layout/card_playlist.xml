<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp">

            <ImageView
                android:id="@+id/imageViewPlaylistPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/baseline_queue_music_24" />

            <FrameLayout
                android:id="@+id/layoutPlaylistCollage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/imageViewPlaylistCoverTopLeft"
                    android:layout_width="31dp"
                    android:layout_height="31dp"
                    android:layout_gravity="top|start"
                    android:scaleType="centerCrop"
                    android:src="@drawable/baseline_queue_music_24" />

                <ImageView
                    android:id="@+id/imageViewPlaylistCoverTopRight"
                    android:layout_width="31dp"
                    android:layout_height="31dp"
                    android:layout_gravity="top|end"
                    android:scaleType="centerCrop"
                    android:src="@drawable/baseline_queue_music_24" />

                <ImageView
                    android:id="@+id/imageViewPlaylistCoverBottomLeft"
                    android:layout_width="31dp"
                    android:layout_height="31dp"
                    android:layout_gravity="bottom|start"
                    android:scaleType="centerCrop"
                    android:src="@drawable/baseline_queue_music_24" />

                <ImageView
                    android:id="@+id/imageViewPlaylistCoverBottomRight"
                    android:layout_width="31dp"
                    android:layout_height="31dp"
                    android:layout_gravity="bottom|end"
                    android:scaleType="centerCrop"
                    android:src="@drawable/baseline_queue_music_24" />
            </FrameLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textViewPlaylistName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textViewTracksCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@android:color/darker_gray"
                android:textSize="14sp" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
